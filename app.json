{
  "expo": {
    "name": "MarZlog",
    "slug": "marzlog-app",
    "owner": "marzlogs-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "marzlog",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marzlog.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "사진 촬영을 위해 카메라 접근 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "사진을 업로드하고 촬영 위치 등 추억을 기록하기 위해 사진 라이브러리 접근 권한이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "촬영한 사진을 저장하기 위해 사진 라이브러리 쓰기 권한이 필요합니다.",
        "NSFaceIDUsageDescription": "사진과 일기를 안전하게 보호하기 위해 Face ID를 사용합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.marzlog.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "사진과 일기를 안전하게 보호하기 위해 Face ID를 사용합니다."
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "사진을 업로드하고 추억을 기록하기 위해 사진 라이브러리 접근 권한이 필요합니다.",
          "cameraPermission": "사진 촬영을 위해 카메라 접근 권한이 필요합니다."
        }
      ],
      ["expo-alternate-app-icons", {
        "icons": {
          "coral": "./assets/images/app-icons/coral.png",
          "red": "./assets/images/app-icons/red.png"
        }
      }],
      ["expo-notifications", {
        "icon": "./assets/images/notification-icon.png",
        "color": "#8B5CF6",
        "androidMode": "default",
        "androidCollapsedTitle": "MarZlog 알림"
      }],
      ["@react-native-kakao/core", {
        "nativeAppKey": "2ef2adfdcd23585a092e8bebba21d60c",
        "android": {
          "authCodeHandlerActivity": true
        },
        "ios": {
          "handleKakaoOpenUrl": true
        }
      }],
      ["expo-build-properties", {
        "android": {
          "extraMavenRepos": ["https://devrepo.kakao.com/nexus/content/groups/public/"],
          "extraProguardRules": "-keep class com.kakao.** { *; }",
          "packagingOptions": {
            "pickFirst": ["**/libc++_shared.so"]
          }
        }
      }],
      ["@sentry/react-native/expo", {
        "organization": "jjsim-inc",
        "project": "react-native"
      }],
      "expo-apple-authentication",
      "expo-video",
      "./plugins/withGradleMemory",
      "./plugins/withPrivacyManifest",
      [
        "expo-media-library",
        {
          "photosPermission": "사진을 갤러리에 저장하기 위해 접근 권한이 필요합니다.",
          "savePhotosPermission": "사진을 갤러리에 저장하기 위해 접근 권한이 필요합니다.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/992b64cc-e784-4984-8e08-fdc26f45088b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "992b64cc-e784-4984-8e08-fdc26f45088b"
      }
    }
  }
}
